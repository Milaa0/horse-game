@page
@model IndexModel
@{
    ViewData["Title"] = "T-Horse Game";
}

<div class="text-center">
    <canvas id="gameCanvas" width="800" height="300"></canvas>
</div>

<style>
    body {
        background-color: white;
    }
    canvas {
        background-color: #ecf0f1;
        border: 4px solid #d69a90;
        border-radius: 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        background: linear-gradient(to bottom, #ecf0f1 80%, #c08070 80%);
        margin-top: 50px;
    }
    h1 {
        color: white;
    }
</style>

<script type="module" src="~/js/main.js"></script>